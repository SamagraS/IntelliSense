## STAGE 2: DATA DISCOVERY AND SOURCE RELIABILITY
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

For each case_id, validate that all required sources are present:

REQUIRED SOURCES PER CASE:
  CRITICAL (block scoring if absent):
    □ At least 3 years of financial_statements_line_items (FY2021-22, FY2022-23, FY2023-24)
    □ At least 12 months of banktransactions
    □ At least 12 months of gstfilings
    □ mca_company_master entry exists for CIN

  HIGH PRIORITY (warn if absent):
    □ alm_data (required for NBFC sector; warn for others)
    □ borrowing_profile (at least 1 facility row)
    □ shareholding_pattern_quarterly (at least 1 quarter)
    □ litigation_risk_summary_entity for both company and promoter

  STANDARD (note if absent):
    □ rating_reports_master (at least 1 report)
    □ board_governance_signals (at least 1 board meeting processed)
    □ portfolio_performance (required if sector = NBFC)
    □ site_visit_observations (at least 1 record)
    □ management_interview_notes (at least 1 record)
    □ news_articles_crawled (at least 10 articles)

SOURCE RELIABILITY CHECKS:
  - document_classification: all records must have validation_status = 'approved'
    → BLOCK: any document with validation_status = 'denied' used in analysis
    → WARN: any document with validation_status = 'pending' still in pipeline
  - extraction_confidence < 75 on any field → flag for manual review
  - OCR-derived fields: check source_document_id is non-null and exists in document store

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
## STAGE 3: SCHEMA AND STRUCTURAL VALIDITY
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

Run the following structural checks on every table before analysis:

--- TABLE: case_metadata ---
  PK UNIQUE: case_id not null, unique per row
  FORMAT: cin matches regex ^[LU][0-9]{5}[A-Z]{2}[0-9]{4}[A-Z]{3}[0-9]{6}$
  FORMAT: pan matches regex ^[A-Z]{5}[0-9]{4}[A-Z]{1}$
  ENUM: sector ∈ {Manufacturing, NBFC, Retail, Infrastructure, Pharma, Other}
  RANGE: annual_turnover_cr > 0
  RANGE: proposed_amount_inr > 0
  RANGE: tenure_months > 0
  RANGE: proposed_interest_rate_pct in [0, 50] if provided

--- TABLE: gstfilings ---
  PK UNIQUE: (case_id, gstin, filing_month) must be unique
  FORMAT: gstin is 15 characters alphanumeric
  FORMAT: filing_month is valid YYYY-MM
  RANGE: gstr3b_revenue_declared >= 0
  RANGE: gstr2a_reported_purchases >= 0
  RANGE: gstr3b_tax_paid >= 0
  RANGE: gstr2a_vs_3b_divergence_pct in [-200, 200]
  ENUM: filing_status ∈ {filed, missing, late_filed}
  NULL CHECK: filing_month, gstin, filing_status must not be null

--- TABLE: itrfinancials ---
  PK UNIQUE: (case_id, assessment_year) must be unique
  CONSISTENCY: financial_year = "FY" + (assessment_year_start_year), e.g. AY2023-24 → FY2022-23
  RANGE: declared_gross_income >= declared_net_income (gross >= net always)
  RANGE: total_tax_paid >= 0
  RANGE: director_remuneration_total >= 0
  NULL CHECK: declared_gross_income, declared_net_income must not be null

--- TABLE: banktransactions ---
  PK UNIQUE: transaction_id not null, unique
  ENUM: transaction_type ∈ {credit, debit}
  RANGE: amount > 0 (always positive; type determines direction)
  RANGE: running_balance can be negative (overdraft) but flag if < -1 Cr unexplained
  TEMPORAL: transaction_date must not be future date
  TEMPORAL: running_balance must be monotonically consistent within account sequence
  NULL CHECK: transaction_date, amount, transaction_type, bank_account_no not null

--- TABLE: bankmonthlysummary ---
  AGGREGATE CONSISTENCY: total_credits in month must equal SUM(amount) for credits
    in banktransactions for same (company_id, bank_account_no, month)
    TOLERANCE: ±0.5% allowed for rounding
  RANGE: average_balance can be negative but flag
  RANGE: bounce_count >= 0, emi_obligations_detected >= 0
  TEMPORAL: no gaps > 2 months without explanation flag

--- TABLE: alm_data ---
  COMPLETENESS: exactly 8 rows per case_id covering all buckets:
    {1-7d, 8-14d, 15-30d, 1-3m, 3-6m, 6-12m, 1-3y, >3y}
  ENUM: maturity_bucket ∈ the 8 values above
  RANGE: assets_bucket_inr >= 0
  RANGE: liabilities_bucket_inr >= 0
  COMPUTED: cumulative_gap_inr[i] = cumulative_gap_inr[i-1] + (assets[i] - liabilities[i])
    → Recompute and compare; flag if difference > 1 (rounding threshold)
  COMPUTED: gap_as_pct_of_assets = (cumulative_gap_inr / SUM(assets_bucket_inr)) * 100
    → Recompute per bucket; flag mismatch > 0.1%
  CONSISTENCY: negative_gap_flag must be True iff liabilities_bucket_inr > assets_bucket_inr
  RANGE: extraction_confidence in [0, 100]

--- TABLE: shareholding_pattern_quarterly ---
  RANGE: promoter_holding_pct in [0, 100]
  RANGE: institutional_holding_pct in [0, 100]
  RANGE: public_holding_pct in [0, 100]
  SUM CHECK: promoter_holding_pct + institutional_holding_pct + public_holding_pct
    must be in [99.0, 101.0] (tolerance for small rounding)
  CONSISTENCY: promoter_shares_pledged_pct <= promoter_holding_pct
  TEMPORAL: filing_date must be a valid date; quarters should be 3 months apart
  NULL CHECK: promoter_holding_pct, promoter_shares_pledged_pct not null

--- TABLE: promoter_pledge_analysis ---
  ENUM: pledge_risk_flag ∈ {normal, caution, high_risk, critical}
  CONSISTENCY: pledge_risk_flag must match these thresholds:
    normal: promoter_pledged_pct < 40
    caution: 40 <= promoter_pledged_pct < 60
    high_risk: 60 <= promoter_pledged_pct < 75
    critical: promoter_pledged_pct >= 75
  → Recompute and flag any mismatch
  COMPUTED: qoq_change_percentage_points = current_pledged - previous_quarter_pledged
  CONSISTENCY: trend must match qoq_change direction
    increasing: qoq_change > 0.5
    decreasing: qoq_change < -0.5
    stable: abs(qoq_change) <= 0.5

--- TABLE: borrowing_profile ---
  UNIQUENESS: (case_id, lender_name, facility_type) should be unique or have distinct source docs
  ENUM: facility_type ∈ {term_loan, working_capital, cash_credit,
                          letter_of_credit, bank_guarantee, overdraft}
  RANGE: sanctioned_amount_inr > 0
  RANGE: outstanding_amount_inr >= 0
  CONSISTENCY: outstanding_amount_inr <= sanctioned_amount_inr
  RANGE: interest_rate_pct in [0, 50]; flag if > 18 (high risk threshold)
  ENUM: payment_track_record ∈ {regular, irregular, arrears, default}
  NULL CHECK: lender_name, facility_type, sanctioned_amount_inr not null

--- TABLE: portfolio_performance ---
  REQUIRED FOR: case_id where sector = NBFC
  RANGE: gross_npa_pct in [0, 100]
  RANGE: net_npa_pct in [0, 100]
  CONSISTENCY: net_npa_pct <= gross_npa_pct
  RANGE: restructured_assets_pct in [0, 100]
  RANGE: top_10_borrower_concentration_pct in [0, 100]
  RANGE: provisioning_coverage_ratio in [0, 100]
  RANGE: portfolio_outstanding_inr > 0

--- TABLE: financial_statements_line_items ---
  COVERAGE: must have at least 3 distinct financial_years per case_id
  ENUM: statement_type ∈ {PL, BalanceSheet, CashFlow}
  REQUIRED LINE ITEMS (minimum set per year):
    PL: Revenue_from_Operations, EBITDA, PAT, Interest_Expense, Depreciation
    BalanceSheet: Total_Assets, Total_Liabilities, Net_Worth, Total_Debt,
                  Current_Assets, Current_Liabilities
    CashFlow: Cash_Flow_from_Operations
  RANGE: extraction_confidence in [0, 100]; flag if < 75
  NULL CHECK: line_item_standardized_name, amount_inr, financial_year not null

--- TABLE: computed_financial_ratios ---
  7 REQUIRED RATIOS per financial_year:
    DSCR, Debt_to_Equity, Interest_Coverage, Current_Ratio,
    EBITDA_Margin, Revenue_CAGR, PAT_Margin
  RECOMPUTE AND VERIFY:
    DSCR = (Net_Operating_Income or EBITDA) / Annual_Debt_Service
    Debt_to_Equity = Total_Debt / Net_Worth
    Interest_Coverage = EBIT / Interest_Expense
    Current_Ratio = Current_Assets / Current_Liabilities
    EBITDA_Margin = (EBITDA / Revenue_from_Operations) * 100
    PAT_Margin = (PAT / Revenue_from_Operations) * 100
    Revenue_CAGR = ((Revenue_Year3 / Revenue_Year1) ^ (1/2) - 1) * 100
  FLAG if recomputed value differs from stored by > 1% relative

--- TABLE: auditor_notes ---
  COVERAGE: at least 1 row per financial_year in financial_statements_line_items
  CONSISTENCY: if going_concern_flag = True then has_qualification must be True
  CONSISTENCY: if has_emphasis_of_matter = True then emphasis_text must not be null
  NULL CHECK: financial_year, auditor_firm_name, has_qualification, has_emphasis_of_matter

--- TABLE: mca_company_master ---
  PK UNIQUE: company_cin matches CIN format regex
  ENUM: company_status ∈ {active, strike_off, amalgamated, dissolved, under_liquidation}
  CRITICAL FLAG: company_status != 'active' → emit CRITICAL validation alert
  NULL CHECK: company_name, company_status, date_of_incorporation

--- TABLE: mca_directors ---
  UNIQUENESS: (director_din, company_cin) pair should be unique for active directorships
  ENUM: din_status ∈ {active, deactivated, disqualified}
  CRITICAL FLAG: din_status = 'disqualified' → emit CRITICAL alert (Character C)
  TEMPORAL: resignation_date must be null for current directors or > appointment_date

--- TABLE: mca_charges_registered ---
  RANGE: charge_amount_inr > 0
  ENUM: charge_status ∈ {live, satisfied, partially_satisfied}
  ENUM: charge_type ∈ {mortgage, hypothecation, pledge, other}
  TEMPORAL: charge_modification_date >= charge_creation_date if not null
  CROSS-CHECK: lender in charge_holder_name should ideally appear in borrowing_profile
    → flag if mismatch > 2 lenders (possible unreported facilities)

--- TABLE: ecourts_cases_raw ---
  PK UNIQUE: case_number not null, unique
  ENUM: case_type ∈ {DRT, NCLT, civil, criminal, arbitration, consumer_dispute, other}
  ENUM: case_status ∈ {active, disposed, pending, dismissed}
  TEMPORAL: filing_date must not be future date
  TEMPORAL: last_hearing_date >= filing_date
  NULL CHECK: case_type, case_status, court_name not null

--- TABLE: litigation_risk_summary_entity ---
  RECOMPUTE: total_active_cases = COUNT(ecourts_cases_raw where case_status = 'active')
             for that entity
  RECOMPUTE: drt_cases_active_count = COUNT where case_type = 'DRT' and active
  RECOMPUTE: litigation_density_score =
    (DRT_count × 10 + NCLT_count × 8 + Criminal_count × 5 + Civil_count × 1) / 10
    CAP AT 10
  → Flag if stored score differs from recomputed by > 0.1
  COVERAGE: must exist for BOTH entity_type = 'company' AND entity_type = 'promoter'
    for each case_id → warn if promoter record missing

--- TABLE: news_articles_crawled ---
  COVERAGE: at least 10 articles per case_id
  NULL CHECK: article_url, published_date, search_query_used not null
  TEMPORAL: published_date must not be future date
  ENUM: crawl_phase ∈ {background_deep_crawl, live_refresh}
  NULL CHECK: article_full_text not null or empty (reject empty-text articles from scoring)

--- TABLE: news_risk_signals ---
  RANGE: severity_score in [0.0, 1.0]
  CONSISTENCY: is_high_severity = True iff severity_score > 0.6
  ENUM: signal_category valid (6 allowed categories)
  CROSS-CHECK: article_id must exist in news_articles_crawled

--- TABLE: site_visit_observations ---
  ENUM: observation_category ∈ valid enum values
  RANGE: score_adjustment_points in [-2.0, +2.0]
  CONSISTENCY: risk_impact_direction and score_adjustment_points must agree:
    positive direction: score_adjustment > 0
    negative direction: score_adjustment < 0
    neutral: score_adjustment = 0
    critical_negative: score_adjustment <= -1.5
  WORKFLOW: if verification_status = 'pending' and observation > 7 days old → warn

--- TABLE: management_interview_notes ---
  ENUM: management_credibility_assessment ∈ valid 5 values
  RANGE: score_adjustment_points in [-2.0, +2.0]
  CONSISTENCY:
    contradictory_to_documents → score_adjustment <= -1.2
    evasive → score_adjustment in [-1.5, -0.5]
    confident_and_consistent → score_adjustment >= 0
  WORKFLOW: if requires_document_verification = True and verification_status = 'pending'
    and interview > 3 days old → warn

--- TABLE: precognitive_signals ---
  ENUM: signal_category ∈ {velocity_trend, triangulation_flag,
                             sentiment_divergence, network_contagion}
  ENUM: severity ∈ {low, medium, high, critical}
  RANGE: score_impact in [-2.0, +2.0]
  CONSISTENCY: severity must match score_impact magnitude:
    low: |score_impact| < 0.5
    medium: 0.5 <= |score_impact| < 1.0
    high: 1.0 <= |score_impact| < 1.5
    critical: |score_impact| >= 1.5
  DEDUPE: no two signals with same (case_id, signal_category, signal_description) — exact duplicate
  CROSS-CHECK: all items in data_sources_used must reference tables/docs that exist for case_id

--- TABLE: document_classification ---
  ENUM: validation_status ∈ {pending, approved, denied, edited}
  WORKFLOW GATE: no document with validation_status ∈ {pending, denied} may be used
    as source_document_id in ANY downstream table
  CONSISTENCY: if validation_status = 'denied' then denial_reason must not be null
  CONSISTENCY: if validation_status = 'edited' then human_validated_type must differ
    from auto_classified_type

--- TABLE: schema_mappings ---
  COVERAGE: one record must exist per (case_id, document_type) where document is approved
  CONSISTENCY: all keys in field_mappings must exist in the document's extracted data
  NULL CHECK: case_id, document_type, field_mappings not null

